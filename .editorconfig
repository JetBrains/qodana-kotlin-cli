root = true

# Universal text-file conventions. Per-language overrides below either add
# a constraining indent_size where a real convention exists (and no
# specialized formatter owns the language), or relax these globals via
# `unset` for files we don't own (Gradle wrapper, imported LICENSE).
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# 2-space convention for hand-written config files; no specialized formatter
# owns these. *.xml is intentionally omitted — every tracked instance is a
# detekt or ktlint baseline (tool-generated). Tool-generated JSON under
# qodana-cli/src/main/resources/META-INF/native-image/ (GraalVM agent
# output) is unset further down — a nested .editorconfig there would be
# bundled into the published JAR by Gradle's default resource processing,
# so the exclusion lives here instead.
[*.{yml,yaml,toml,json}]
indent_size = 2

# Kotlin formatting is owned by ktlint, which reads .editorconfig directly
# and defaults to indent_size = 4. No [*.{kt,kts}] block is needed here.

# Markdown formatting is owned by Prettier (see .pre-commit-config.yaml).
# This override only relaxes trailing-whitespace trimming, which is
# meaningful in markdown as a hard line break.
[*.md]
trim_trailing_whitespace = false

# dockerfile-x lib/ includes and thin images use tab-indented `<<-EOT`
# heredocs: the `<<-` form strips LEADING TABS (not spaces) from the body,
# so tabs are load-bearing for keeping the resolved Dockerfile readable.
# This reconciles the repo's space default with the Dockerfile convention.
[*.dockerfile]
indent_style = tab

# Gradle wrapper / daemon files — regenerated by `./gradlew wrapper` and
# `./gradlew updateDaemonJvm`; we don't dictate their format.
[{gradlew,gradlew.bat,gradle/wrapper/gradle-wrapper.properties,gradle/gradle-daemon-jvm.properties}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# Apache 2.0 license text — imported verbatim; we don't dictate its format.
[LICENSE]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# GraalVM native-image agent regenerates these JSON configs from runtime
# traces; the format is determined by the tool, not by this project's
# conventions. A nested .editorconfig in this dir would be bundled into
# the published JAR (this path is under src/main/resources/), so we exclude
# from the root config via a path-rooted wildcard instead.
[qodana-cli/src/main/resources/META-INF/native-image/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
