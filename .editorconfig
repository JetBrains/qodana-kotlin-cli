root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
indent_size = 4

[*.{yml,yaml,toml}]
indent_size = 2

[*.md]
# Markdown formatting is owned by Prettier (see .pre-commit-config.yaml).
# This override only ensures editorconfig-aware tools don't trim trailing
# whitespace, which is meaningful in markdown as a hard line break.
trim_trailing_whitespace = false
