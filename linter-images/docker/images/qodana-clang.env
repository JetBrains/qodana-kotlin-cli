# qodana-clang — Qodana Community for C/C++ (image name = repoName). Feed-less linter.
# No IDE dist (no QD_LINTER_SLUG/QD_VERSION/QD_BUILD/QD_PRODUCT_INFO_CODE): clang-tidy is the only
# aux tool, fetched by lib/tools.dockerfile from the PRIVATE qodana-cli-deps mirror (token-gated;
# CI supplies QODANA_CLI_DEPS_TOKEN). The inner CLI is qodana-clang, pulled from this repo's release
# (CLI_SOURCE=release, a compose build arg). CLI_BASE_STAGE=tools (clang has no dist) is also a build
# arg the compose clang service passes — NOT an .env key (EnvContractTest enforces the exact key set).
# CLANG/CLANG_OS are the DEFAULT build cell; the CI matrix overrides them per clang-versions.txt row.
#
# CLI_VERSION: unlike jvm/android (whose `qodana` archive carries NO version in its asset name), the
# qodana-clang TOOL asset is `qodana-clang_<CLI_VERSION>_linux_amd64` (CliArtifactResolver), so on the
# release path CLI_VERSION MUST equal the version segment of the release tag pinned in compose.yaml's
# CLI_RELEASE_BASE_URL, or the download 404s. ComposeContractTest enforces that equality, so bump the
# two in lockstep (the release-tag bump is currently manual; the guard fails loudly on any drift).
QD_BASE_IMAGE=dhi.io/debian-base:bookworm@sha256:802b1fe0c2ac7827f82f4a33918f3bd69293fe83d18ddf471ae57f4312400cd5
CLI_BINARY=qodana-clang
CLI_VERSION=2026.2.1-nightly.20260605
CLI_OS=linux
CLI_ARCH=amd64
CLANG=19
CLANG_OS=bookworm
# renovate: datasource=custom.qodana-cli-deps depName=clang-tidy versioning=loose
CLANG_TIDY_VERSION=1.0.0
CLANG_TIDY_MIRROR=https://packages.jetbrains.team/files/p/sa/qodana-cli-deps/clang-tidy
TINI_VERSION=v0.19.0
TINI_ARCH=amd64
TINI_SHA256=93dcc18adc78c65a028a84799ecf8ad40c936fdfc5f2a57b1acda5a8117fa82c
