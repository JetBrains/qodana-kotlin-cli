# qodana-cdnet — Qodana Community for .NET (image name = repoName). Feed-less linter.
# No IDE dist (no QD_LINTER_SLUG/QD_VERSION/QD_PRODUCT_INFO_CODE): the ReSharper CLT (InspectCode) is
# the only aux tool, installed by lib/resharper-clt.dockerfile to /opt/qodana-cdnet/bin (on PATH) from
# the PRIVATE qodana-cli-deps mirror (token-gated; CI supplies QODANA_READ_SPACE_PACKAGES_TOKEN). The inner CLI is
# qodana-cdnet, pulled from this repo's release (CLI_SOURCE=release, a compose build arg).
# CLI_BASE_STAGE=tools and PRIVILEGED_BASE_STAGE=dotnet-toolchain are build ARGs the compose service
# passes — NOT .env keys (EnvContractTest enforces the exact key set).
#
# CLI_VERSION: the qodana-cdnet TOOL asset is qodana-cdnet_<CLI_VERSION>_linux_amd64, so on the release
# path CLI_VERSION MUST equal the version segment of the release tag pinned in compose.yaml's
# CLI_RELEASE_BASE_URL (ComposeContractTest enforces it). Bump the two in lockstep.
QD_BASE_IMAGE=dhi.io/debian-base:bookworm@sha256:802b1fe0c2ac7827f82f4a33918f3bd69293fe83d18ddf471ae57f4312400cd5
CLI_BINARY=qodana-cdnet
CLI_VERSION=2026.2.1-nightly.20260605
CLI_OS=linux
CLI_ARCH=amd64
# renovate: datasource=custom.qodana-cli-deps depName=resharper-clt versioning=loose
CLT_VERSION=2026.1.3
CLT_MIRROR=https://packages.jetbrains.team/files/p/sa/qodana-cli-deps/resharper-clt
TINI_VERSION=v0.19.0
TINI_ARCH=amd64
TINI_SHA256=93dcc18adc78c65a028a84799ecf8ad40c936fdfc5f2a57b1acda5a8117fa82c
