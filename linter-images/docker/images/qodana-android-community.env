# qodana-android-community — Qodana Community for Android (image name = repoName). Feed code QDANDC,
# PUBLIC feed: this `.env` OMITS QD_DISTRIBUTION_FEED and relies on lib/dist.dockerfile's public-feed
# default. Reuses the qodana-jvm-community dist (QD_LINTER_SLUG=qodana-jvm-community) — the Community
# twin of how qodana-android reuses qodana-jvm — but carries its OWN QD_VERSION/QD_BUILD pin
# (QODANA_ANDROID_COMMUNITY_* in phase-0-decisions; EnvContractTest asserts that, NOT byte-identity with
# qodana-jvm-community.env). No node; adds the SDK + Corretto. DIST_BASE_STAGE=android-toolchain layers the
# dist onto the SDK stage. Trixie hardened base (shared by the new debian-base images).
QD_LINTER_SLUG=qodana-jvm-community
QD_VERSION=2026.1
QD_BUILD=261.25881
QD_RELEASE_TYPE=release
QD_PRODUCT_INFO_CODE=IU
QD_BASE_IMAGE=dhi.io/debian-base:trixie-debian13-dev@sha256:68b5f4c2c789b99dc6ab7574c7e695e724646f64616619c48c3245f8aaeae459
DIST_BASE_STAGE=android-toolchain
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
ANDROID_SDK_VERSION=14742923
ANDROID_SDK_SHA256=04453066b540409d975c676d781da1477479dde3761310f1a7eb92a1dfb15af7
CORRETTO11_IMAGE=amazoncorretto:11@sha256:a5392f65a844fe799859a09b5dabb1a07c627268fd2376760beb962d25cda58d
CORRETTO17_IMAGE=amazoncorretto:17@sha256:1c4922080f55a03925b39012e8c34c0bea4e25e3e3df2276f5e0080a50d80b5e
DEVICEID=qodana
