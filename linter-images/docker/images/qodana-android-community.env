# qodana-android-community — Qodana Community for Android (image name = repoName). Feed code QDANDC,
# PUBLIC feed: this `.env` OMITS QD_DISTRIBUTION_FEED and relies on lib/dist.dockerfile's public-feed
# default. Reuses the qodana-jvm-community dist (QD_LINTER_SLUG=qodana-jvm-community) — the Community
# twin of how qodana-android reuses qodana-jvm — so it shares the Community JVM QD_VERSION/QD_BUILD/
# QD_PRODUCT_INFO_CODE pins (EnvContractTest asserts byte-identity against qodana-jvm-community.env and
# phase-0-decisions.md). No node; adds the SDK + Corretto. DIST_BASE_STAGE=android-toolchain layers the
# dist onto the SDK stage. Trixie hardened base (shared by the new debian-base images).
QD_LINTER_SLUG=qodana-jvm-community
QD_VERSION=2025.3
QD_BUILD=253.31821
QD_RELEASE_TYPE=release
QD_PRODUCT_INFO_CODE=IC
QD_BASE_IMAGE=dhi.io/debian-base:trixie-debian13@sha256:e440d0dabdc54675aa9601f0d794c39f549b6178946cfeffd3b5a31da33ec2d3
DIST_BASE_STAGE=android-toolchain
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
CLI_ARCH=amd64
ANDROID_SDK_VERSION=14742923
ANDROID_SDK_SHA256=04453066b540409d975c676d781da1477479dde3761310f1a7eb92a1dfb15af7
CORRETTO11_IMAGE=amazoncorretto:11@sha256:4c5be387478a9fb419496c47cb07865e8c6d49af7db40f831b05256183122d06
CORRETTO17_IMAGE=amazoncorretto:17@sha256:07350da9409a144fffd92f6d97736fc2273797768fedbf57ecc28a4713986937
DEVICEID=qodana
TINI_VERSION=v0.19.0
TINI_ARCH=amd64
TINI_SHA256=93dcc18adc78c65a028a84799ecf8ad40c936fdfc5f2a57b1acda5a8117fa82c
