# qodana-android — Qodana for Android (image name = repoName). Reuses the qodana-jvm dist.
# Shares jvm's QD_VERSION/QD_BUILD/QD_BASE_IMAGE pins (EnvContractTest asserts byte-identity) and
# QD_LINTER_SLUG=qodana-jvm so provision-dist pulls the same dist. No node; adds the SDK + Corretto.
# DIST_BASE_STAGE=android-toolchain layers the dist onto the SDK stage (jvm omits it → defaults to base).
QD_LINTER_SLUG=qodana-jvm
QD_VERSION=2025.3
QD_BUILD=253.31821
QD_CHANNEL=public
QD_RELEASE_TYPE=release
QD_PRODUCT_INFO_CODE=IU
QD_BASE_IMAGE=dhi.io/debian-base:bookworm@sha256:802b1fe0c2ac7827f82f4a33918f3bd69293fe83d18ddf471ae57f4312400cd5
DIST_BASE_STAGE=android-toolchain
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
CLI_ARCH=amd64
ANDROID_SDK_VERSION=14742923
ANDROID_SDK_SHA256=04453066b540409d975c676d781da1477479dde3761310f1a7eb92a1dfb15af7
CORRETTO11_IMAGE=amazoncorretto:11@sha256:4c5be387478a9fb419496c47cb07865e8c6d49af7db40f831b05256183122d06
CORRETTO17_IMAGE=amazoncorretto:17@sha256:07350da9409a144fffd92f6d97736fc2273797768fedbf57ecc28a4713986937
DEVICEID=qodana
TINI_VERSION=v0.19.0
TINI_ARCH=amd64
TINI_SHA256=93dcc18adc78c65a028a84799ecf8ad40c936fdfc5f2a57b1acda5a8117fa82c
