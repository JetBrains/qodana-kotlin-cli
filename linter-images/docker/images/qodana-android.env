# qodana-android — Qodana for Android (image name = repoName). Reuses the qodana-jvm dist
# (QD_LINTER_SLUG=qodana-jvm) on the internal nightly feed (sha256/eap); it carries its OWN
# QODANA_ANDROID_* pin, kept equal to qodana-jvm's build (same dist). No node; adds the SDK + Corretto.
# DIST_BASE_STAGE=android-toolchain layers the dist onto the SDK stage.
QD_LINTER_SLUG=qodana-jvm
QD_VERSION=2026.3
QD_BUILD=263.568.2578
QD_RELEASE_TYPE=eap
QD_DISTRIBUTION_FEED=https://packages.jetbrains.team/files/p/sa/qodana-dist-internal/feed
QD_VERIFY_MODE=sha256
QD_PRODUCT_INFO_CODE=IU
QD_BASE_IMAGE=dhi.io/debian-base:bookworm@sha256:802b1fe0c2ac7827f82f4a33918f3bd69293fe83d18ddf471ae57f4312400cd5
DIST_BASE_STAGE=android-toolchain
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
ANDROID_SDK_VERSION=14742923
ANDROID_SDK_SHA256=04453066b540409d975c676d781da1477479dde3761310f1a7eb92a1dfb15af7
CORRETTO11_IMAGE=amazoncorretto:11@sha256:a5392f65a844fe799859a09b5dabb1a07c627268fd2376760beb962d25cda58d
CORRETTO17_IMAGE=amazoncorretto:17@sha256:1c4922080f55a03925b39012e8c34c0bea4e25e3e3df2276f5e0080a50d80b5e
DEVICEID=qodana
