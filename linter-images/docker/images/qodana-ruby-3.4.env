# qodana-ruby-3.4 — Qodana for Ruby/RubyMine, the RUBY 3.4 variant. Identical to qodana-ruby (the
# PRIMARY 3.3 variant) in EVERY key EXCEPT QD_BASE_IMAGE (the 3.4 DHI base digest). Shares the SAME RM
# dist (QD_LINTER_SLUG=qodana-ruby — the IDE dist is ruby-runtime-agnostic, the android precedent), so
# the bump bumper rewrites the single QODANA_RUBY_BUILD row idempotently across all 3 variants. Feed
# code QDRUBY, EAP (the feed has no `release` entries). Internal nightly dist feed:
# unsigned tar.gz, sha256-only; the build mounts QODANA_READ_SPACE_PACKAGES_TOKEN (compose.private.yaml).
# Builds on the DHI ruby base (ruby PRE-BAKED, NO node), so LAYERS the node
# toolchain + the in-place eslint pin + the in-place lib/toolchain/ruby.dockerfile gem-cache redirect,
# and INCLUDEs lib/privileged.dockerfile (source PRIVILEGED=true). DIST_BASE_STAGE=privileged is an .env
# KEY (the dist layers onto privileged); PRIVILEGED_BASE_STAGE=base is a COMPOSE BUILD ARG (privileged
# FROMs base). uid 1000 is FREE on the ruby base, so default 1000, NO uid keys. eslint is pinned in
# lib/toolchain/eslint/package.json. Pins live in docs/phase-0-decisions.md; EnvContractTest asserts
# byte-identity for the dist pins + the 3.4 base digest. Key set = jvm's key set + DIST_BASE_STAGE.
QD_LINTER_SLUG=qodana-ruby
QD_VERSION=2026.3
# renovate: datasource=custom.qodana-dist depName=qodana-ruby versioning=loose
QD_BUILD=263.148.1874
QD_DISTRIBUTION_FEED=https://packages.jetbrains.team/files/p/sa/qodana-dist-internal/feed
QD_VERIFY_MODE=sha256
QD_PRODUCT_INFO_CODE=RM
QD_BASE_IMAGE=dhi.io/ruby:3.4-debian13-dev@sha256:3f86a864dbd00ad09e92268c0cac6604fe2e472604a16e06ea826d57cae45abd
DIST_BASE_STAGE=privileged
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
NODE_MAJOR=20
