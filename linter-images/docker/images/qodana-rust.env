# qodana-rust — Qodana Ultimate for Rust/RustRover (image name = repoName). Feed code QDRST. Internal
# nightly dist feed: unsigned tar.gz, sha256-only (no GPG .asc); the build mounts
# QODANA_READ_SPACE_PACKAGES_TOKEN (compose.private.yaml).
# RustRover-on-trixie-base: the shared trixie base ships NO Rust, so rust layers an install STAGE
# (lib/toolchain/rust.dockerfile, the conda/clang pattern) that fetches a sha-pinned rustup-init and
# installs the RUST_VERSION toolchain + rust-src; the dist FROMs that stage via
# DIST_BASE_STAGE=rust-toolchain (the conda/android convention). NO node toolchain (NODE_MAJOR): unlike
# go/php, RustRover bundles no JS analysis — the source rust.Dockerfile's ESLINT_VERSION is a dead
# copy-paste vestige (no node_base COPY, no npm install). FIRST eap image alongside ruby
# (QD_RELEASE_TYPE=eap — the feed has ONLY eap entries; consumed by BumpPinsCommand drift). uid 1000 is
# free on the trixie base, so NO uid override. Pins are the concrete values in
# docs/phase-0-decisions.md; EnvContractTest asserts byte-identity for QD_VERSION/QD_BUILD/
# QD_PRODUCT_INFO_CODE/RUST_VERSION/RUSTUP_INIT_SHA256_X86_64/RUSTUP_INIT_SHA256_AARCH64 and the trixie base.
QD_LINTER_SLUG=qodana-rust
QD_VERSION=2026.3
QD_BUILD=262.7982.2437
QD_RELEASE_TYPE=eap
QD_DISTRIBUTION_FEED=https://packages.jetbrains.team/files/p/sa/qodana-dist-internal/feed
QD_VERIFY_MODE=sha256
QD_PRODUCT_INFO_CODE=RR
QD_BASE_IMAGE=dhi.io/debian-base:trixie-debian13-dev@sha256:68b5f4c2c789b99dc6ab7574c7e695e724646f64616619c48c3245f8aaeae459
DIST_BASE_STAGE=rust-toolchain
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
# renovate: datasource=docker depName=rust versioning=docker
RUST_VERSION=1.95.0
RUSTUP_INIT_SHA256_X86_64=4acc9acc76d5079515b46346a485974457b5a79893cfb01112423c89aeb5aa10
RUSTUP_INIT_SHA256_AARCH64=9732d6c5e2a098d3521fca8145d826ae0aaa067ef2385ead08e6feac88fa5792
