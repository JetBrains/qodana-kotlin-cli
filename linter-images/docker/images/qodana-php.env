# qodana-php — Qodana Ultimate for PHP/PhpStorm (image name = repoName). Feed code QDPHP. Internal
# nightly dist feed: unsigned tar.gz, sha256-only (no GPG .asc), eap; the build mounts
# QODANA_READ_SPACE_PACKAGES_TOKEN (compose.private.yaml). Builds on the DHI php language base (PHP
# PRE-BAKED, but NO node and NO composer), so — like qodana-go — it LAYERS the node toolchain (NODE_MAJOR)
# + the in-place eslint pin for JS/TS support, PLUS the composer toolchain. Composer is a cross-image COPY
# (source php.Dockerfile copies it from the upstream composer image), so it opens its own php-toolchain
# stage (FROM base, inheriting node+eslint) and COPYs composer from the digest-pinned COMPOSER_IMAGE;
# DIST_BASE_STAGE=php-toolchain layers the dist onto it (the conda/android pattern). The php base does NOT
# occupy uid 1000 (empirically: /etc/passwd has only root/nonroot/_apt/nobody, like the golang base), so
# qodana-php keeps base.dockerfile's DEFAULT uid 1000 and sets NO uid keys/build args. eslint is pinned in
# lib/toolchain/eslint/package.json (renovate-tracked), NOT here. Pins in docs/phase-0-decisions.md;
# EnvContractTest asserts byte-identity for QD_VERSION/QD_BUILD/QD_PRODUCT_INFO_CODE + the feed/verify/eap
# contract, the php base digest, and COMPOSER_IMAGE.
QD_LINTER_SLUG=qodana-php
QD_VERSION=2026.3
QD_BUILD=262.7881.2010
QD_RELEASE_TYPE=eap
QD_DISTRIBUTION_FEED=https://packages.jetbrains.team/files/p/sa/qodana-dist-internal/feed
QD_VERIFY_MODE=sha256
QD_PRODUCT_INFO_CODE=PS
QD_BASE_IMAGE=dhi.io/php:8.4-dev@sha256:6640324da549fe224c038df12edc886588ea9607cf8121d1424014af1d70d1c6
DIST_BASE_STAGE=php-toolchain
COMPOSER_IMAGE=composer:2.10.0@sha256:1b73755de4f19775ba6087fd5313664493e06fab72b6fc27dc2044e87bb7c4c3
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
NODE_MAJOR=20
