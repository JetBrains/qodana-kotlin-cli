# qodana-python — Qodana Ultimate for Python (image name = repoName). Feed code QDPY. Internal nightly
# dist feed: unsigned tar.gz, sha256-only (no GPG .asc), eap; the build mounts
# QODANA_READ_SPACE_PACKAGES_TOKEN (compose.private.yaml). Ultimate Python = Community Python + node
# (mirrors Ultimate jvm = community-JVM-lineage + node): the conda toolchain is the dist base and node
# appends onto it, so DIST_BASE_STAGE=conda-toolchain layers the dist onto the combined conda(+node)
# stage. Differs from python-community only by the Ultimate PyCharm Pro dist (QDPY feed, product-info PY)
# plus NODE_MAJOR. Pins in docs/phase-0-decisions.md; EnvContractTest asserts byte-identity for
# QD_VERSION/QD_BUILD/QD_PRODUCT_INFO_CODE + the feed/verify/eap contract and the trixie base.
QD_LINTER_SLUG=qodana-python
QD_VERSION=2026.3
QD_BUILD=261.15683.2195
QD_DISTRIBUTION_FEED=https://packages.jetbrains.team/files/p/sa/qodana-dist-internal/feed
QD_VERIFY_MODE=sha256
QD_PRODUCT_INFO_CODE=PY
QD_BASE_IMAGE=dhi.io/debian-base:trixie-debian13-dev@sha256:68b5f4c2c789b99dc6ab7574c7e695e724646f64616619c48c3245f8aaeae459
DIST_BASE_STAGE=conda-toolchain
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
MINICONDA_VERSION=py312_24.5.0-0
MINICONDA_SHA256_X86_64=4b3b3b1b99215e85fd73fb2c2d7ebf318ac942a457072de62d885056556eb83e
MINICONDA_SHA256_AARCH64=70afe954cc8ee91f605f9aa48985bfe01ecfc10751339e8245eac7262b01298d
NODE_MAJOR=20
