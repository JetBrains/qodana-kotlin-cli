# qodana-jvm — Qodana Ultimate for JVM (image name = repoName). Feed code QDJVM.
# Internal nightly dist feed (QD-15032 Task 11): unsigned tar.gz+sha256 (QD_VERIFY_MODE=sha256), eap
# channel. The build mounts QODANA_READ_SPACE_PACKAGES_TOKEN as the space_packages_token secret
# (compose.private.yaml). Pins are the concrete values recorded in docs/phase-0-decisions.md (Spike C);
# EnvContractTest asserts byte-identity for QD_VERSION/QD_BUILD and the feed/verify/eap contract.
QD_LINTER_SLUG=qodana-jvm
QD_VERSION=2026.3
QD_BUILD=263.1362.2630
QD_DISTRIBUTION_FEED=https://packages.jetbrains.team/files/p/sa/qodana-dist-internal/feed
QD_VERIFY_MODE=sha256
QD_PRODUCT_INFO_CODE=IU
QD_BASE_IMAGE=dhi.io/debian-base:bookworm@sha256:802b1fe0c2ac7827f82f4a33918f3bd69293fe83d18ddf471ae57f4312400cd5
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
NODE_MAJOR=20
