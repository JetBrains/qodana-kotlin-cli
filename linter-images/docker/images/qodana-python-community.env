# qodana-python-community — Qodana Community for Python (image name = repoName). Feed code QDPYC,
# PUBLIC feed: this `.env` OMITS QD_DISTRIBUTION_FEED and relies on lib/dist.dockerfile's public-feed
# default. First image on the conda toolchain (no node): DIST_BASE_STAGE=conda-toolchain layers the dist
# onto the Miniconda stage, mirroring how android sets DIST_BASE_STAGE=android-toolchain. Pins are the
# concrete values in docs/phase-0-decisions.md; EnvContractTest asserts byte-identity for QD_VERSION/
# QD_BUILD/QD_PRODUCT_INFO_CODE and the trixie base. Trixie hardened base (shared by the new images).
QD_LINTER_SLUG=qodana-python-community
QD_VERSION=2026.1
QD_BUILD=261.25883
QD_RELEASE_TYPE=release
QD_PRODUCT_INFO_CODE=PY
QD_BASE_IMAGE=dhi.io/debian-base:trixie-debian13-dev@sha256:62bc0610151db7155b7225f1a03c299bf109ab0b884da6777d1f808c7834d4ea
DIST_BASE_STAGE=conda-toolchain
CLI_BINARY=qodana
CLI_VERSION=2026.2
CLI_OS=linux
MINICONDA_VERSION=py312_24.5.0-0
MINICONDA_SHA256_X86_64=4b3b3b1b99215e85fd73fb2c2d7ebf318ac942a457072de62d885056556eb83e
MINICONDA_SHA256_AARCH64=70afe954cc8ee91f605f9aa48985bfe01ecfc10751339e8245eac7262b01298d
