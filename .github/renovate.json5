{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "7 days",
  "automerge": true,
  "automergeStrategy": "squash",
  "customDatasources": {
    "qodana-cli-deps": {
      "defaultRegistryUrlTemplate": "https://packages.jetbrains.team/files/p/sa/qodana-cli-deps/{{packageName}}/versions.json",
      "format": "json",
      // versions.json is {"versions":["v1.0.0", ...]}. Strip the leading `v` so the value written
      // back into CLANG_TIDY_VERSION stays bare: the .env carries `1.0.0` and lib/tools.dockerfile
      // prepends the `v` for the mirror path. Without the strip Renovate writes `v1.0.1` and the
      // build requests `.../vv1.0.1/...`.
      "transformTemplates": ["{ \"releases\": versions.{ \"version\": $replace($, /^v/, \"\") } }"]
    },
    "qodana-dist": {
      "defaultRegistryUrlTemplate": "https://packages.jetbrains.team/files/p/sa/qodana-dist-internal/feed/{{packageName}}.releases.json",
      "format": "json",
      // Feed = one object per slug: {"Releases":[{"Build","MajorVersion","Date",...}]}, eap-only. Keep the
      // pinned major, expose Build as version + Date as releaseTimestamp; Renovate pins the highest
      // within-major Build (the platform-newest). [Releases[...]] forces array context (a single match
      // would otherwise collapse to a scalar); `and Build` drops rows with no Build. The "2026.3" literal
      // is bound to every IDE-dist .env QD_VERSION by RenovateDistDatasourceTest (Renovate has no runtime
      // equivalent — this offline test is the only major-coupling guard). packageName = the dist slug, set
      // per-manager via depNameTemplate (authoritative). Bearer from the hostRules secret below. Replaces
      // the retired drift bump job (QD-15370); a feed that stops returning 2026.3 freezes the pin (stale,
      // not broken) — see the "Datasource liveness" note in the plan.
      "transformTemplates": ["{ \"releases\": [Releases[MajorVersion = \"2026.3\" and Build]].{ \"version\": Build, \"releaseTimestamp\": Date } }"]
    }
  },
  "hostRules": [
    {
      "matchHost": "packages.jetbrains.team",
      "authType": "Bearer",
      "token": "{{ secrets.QODANA_READ_SPACE_PACKAGES_TOKEN }}"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track CLANG_TIDY_VERSION (qodana-cli-deps clang-tidy package tag) in the clang .env (QD-14960). The token-gated versions.json datasource is custom.qodana-cli-deps; the bot supplies QODANA_READ_SPACE_PACKAGES_TOKEN via the hostRules secret above.",
      "managerFilePatterns": ["linter-images/docker/images/qodana-clang.env"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+CLANG_TIDY_VERSION=(?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Track CLT_VERSION (qodana-cli-deps resharper-clt package tag) in the cdnet .env (QD-15021). Token-gated versions.json datasource is custom.qodana-cli-deps; inert until the mirror cdnet->resharper-clt rename lands.",
      "managerFilePatterns": ["linter-images/docker/images/qodana-cdnet.env"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+CLT_VERSION=(?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Track RUST_VERSION (the rustup default-toolchain) in the rust .env AND the byte-identical RUST_VERSION row in phase-0-decisions.md (RustEnvContractTest asserts they match). ONE manager owns both so a bump rewrites them in a single PR — splitting it would red the contract guard between the two PRs (the dockerfile-x/digest managers do the same). The Docker `rust` image tags use the same x.y.z scheme, so the docker datasource + docker versioning track new releases. The companion RUSTUP_INIT_SHA256 pin is version-INDEPENDENT (rustup-init is a static installer), so it is NOT renovate-tracked; refresh it manually only when rustup ships a new installer.",
      "datasourceTemplate": "docker",
      "depNameTemplate": "rust",
      "versioningTemplate": "docker",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-rust.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+RUST_VERSION=(?<currentValue>\\S+)",
        "RUST_VERSION = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Track the stock GraalVM CE pinned in setup-native-build (QD-14917).",
      "managerFilePatterns": [".github/actions/setup-native-build/action.yaml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) extractVersion=(?<extractVersion>\\S+)\\s+java-version:\\s*['\"](?<currentValue>[^'\"]+)['\"]"
      ]
    },
    {
      "customType": "regex",
      "description": "Track the qodana/graalvm-hybridcrt prebuilt (HybridCRT) GraalVM pinned in setup-native-build (QD-14925). The trailing <rev> tag segment bumps on every input change incl. MSVC-only security bumps; the MSVC toolset is intentionally uncaptured so those bumps are offered as upgrades.",
      "managerFilePatterns": [".github/actions/setup-native-build/action.yaml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+default:\\s*['\"](?<currentValue>[^'\"]+)['\"]"
      ]
    },
    {
      "customType": "regex",
      "description": "Track digest-pinned Docker images for the linter images (QD-14960): QD_BASE_IMAGE (dhi.io hardened base), CORRETTO11/17_IMAGE, and COMPOSER_IMAGE in the .env files, plus the JDK_BUILDER_IMAGE ARG default in lib/. The same refs are mirrored byte-identically in phase-0-decisions.md (EnvContractTest asserts QD_BASE_IMAGE byte-identity), so including the decisions doc in the file set updates every occurrence in ONE PR and keeps the contract guard green. The KEY= anchor (uppercase env/ARG name) deliberately excludes the lowercase `# syntax=` directive, which the dockerfile-x manager below owns.",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/^linter-images/docker/images/.*\\.env$/",
        "/^linter-images/docker/lib/.*\\.dockerfile$/",
        "/^linter-images/docs/phase-0-decisions\\.md$/"
      ],
      "matchStrings": [
        "(?:^|\\s)[A-Z][A-Z0-9_]*\\s*=\\s*(?<depName>[^\\s:@=]+):(?<currentValue>[^\\s@]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ]
    },
    {
      "customType": "regex",
      "description": "Track the dockerfile-x syntax frontend pinned in the `# syntax=` directive of every thin image AND the byte-identical DOCKERFILE_X_SYNTAX row in phase-0-decisions.md (SyntaxPinTest asserts they match). ONE manager owns all occurrences so a digest bump rewrites them in a single PR — splitting it across the built-in dockerfile manager and this regex would desync SyntaxPinTest between the two PRs.",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/^linter-images/docker/images/.*\\.dockerfile$/",
        "/^linter-images/docs/phase-0-decisions\\.md$/"
      ],
      "matchStrings": [
        "# syntax=(?<depName>docker\\.io/devthefuture/dockerfile-x):(?<currentValue>[^\\s@]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-python nightly dist build (QD_BUILD) + the byte-identical QODANA_PYTHON_BUILD row; one manager owns both so a bump lands in one PR (EnvContractTest byte-identity). Replaces the retired drift bump job.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-python",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-python.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_PYTHON_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-python-community nightly dist build + QODANA_PYTHON_COMMUNITY_BUILD row.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-python-community",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-python-community.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_PYTHON_COMMUNITY_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-go nightly dist build + QODANA_GO_BUILD row.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-go",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-go.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_GO_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-js nightly dist build + QODANA_JS_BUILD row.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-js",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-js.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_JS_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-php nightly dist build + QODANA_PHP_BUILD row.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-php",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-php.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_PHP_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-rust nightly DIST build + QODANA_RUST_BUILD row. Distinct from the RUST_VERSION manager (the rustup toolchain, not the Qodana dist).",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-rust",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-rust.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_RUST_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-cpp nightly dist build + QODANA_CPP_BUILD row.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-cpp",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-cpp.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_CPP_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-dotnet nightly dist build + QODANA_DOTNET_BUILD row.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-dotnet",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-dotnet.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_DOTNET_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-jvm nightly dist build. android REUSES this dist, so one manager owns qodana-jvm.env + qodana-android.env AND both QODANA_JVM_BUILD + QODANA_ANDROID_BUILD rows (identical build) — one PR keeps all four byte-identical.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-jvm",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-jvm.env",
        "linter-images/docker/images/qodana-android.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_JVM_BUILD = (?<currentValue>\\S+)",
        "\\nQODANA_ANDROID_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-jvm-community nightly dist build. android-community REUSES this dist; one manager owns qodana-jvm-community.env + qodana-android-community.env AND QODANA_JVM_COMMUNITY_BUILD + QODANA_ANDROID_COMMUNITY_BUILD (identical build).",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-jvm-community",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-jvm-community.env",
        "linter-images/docker/images/qodana-android-community.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_JVM_COMMUNITY_BUILD = (?<currentValue>\\S+)",
        "\\nQODANA_ANDROID_COMMUNITY_BUILD = (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "QD-15370: qodana-ruby nightly dist build. One qodana-ruby family image (runtime as a version sub-axis, QD-15369) with one dist + one QODANA_RUBY_BUILD row; this manager owns its .env file + that row.",
      "datasourceTemplate": "custom.qodana-dist",
      "depNameTemplate": "qodana-ruby",
      "versioningTemplate": "loose",
      "managerFilePatterns": [
        "linter-images/docker/images/qodana-ruby.env",
        "linter-images/docs/phase-0-decisions.md"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+QD_BUILD=(?<currentValue>\\S+)",
        "\\nQODANA_RUBY_BUILD = (?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Keep the stock GraalVM pin on the JDK-25 line; the next-JDK migration is a deliberate effort.",
      "matchDepNames": ["graalvm/graalvm-ce-builds"],
      "allowedVersions": "<26"
    },
    {
      "description": "Keep the HybridCRT GraalVM on the JDK-25 line too; a major-line jump is a deliberate migration (QD-14917).",
      "matchDepNames": ["qodana/graalvm-hybridcrt"],
      "allowedVersions": "<26"
    },
    {
      "description": "Bump the dockerfile-x syntax frontend within the 1.x line. Match both the bare and docker.io-prefixed names so the policy applies however the docker datasource normalizes the depName captured from the `# syntax=` directive.",
      "matchPackageNames": ["devthefuture/dockerfile-x", "docker.io/devthefuture/dockerfile-x"],
      "versioning": "semver"
    },
    {
      "description": "qodana-cli-deps bumps (clang-tidy, resharper-clt) need a manual SHA256 refresh (the build verifies the archive), so do not automerge; the PR carries the refresh instructions.",
      "matchDatasources": ["custom.qodana-cli-deps"],
      "automerge": false,
      "prBodyNotes": [
        "clang-tidy: refresh CLANG_TIDY_SHA256 (the `ARG` default in `lib/tools.dockerfile`) — download `clang-tidy-linux-amd64.tar.gz` from the qodana-cli-deps mirror at the new tag (with QODANA_READ_SPACE_PACKAGES_TOKEN) and update the sha256 the clang image build verifies.",
        "resharper-clt: refresh CLT_SHA256 (the `ARG` default in `lib/resharper-clt.dockerfile`) — download `clt.zip` from the qodana-cli-deps mirror at the new tag (with QODANA_READ_SPACE_PACKAGES_TOKEN) and update the sha256 the cdnet image build verifies."
      ]
    }
  ]
}
